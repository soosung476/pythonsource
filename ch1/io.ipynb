     "name": "stdout",
     "output_type": "stream",
     "text": [
      "숫자를 입력하세요\n"
     ]
    }
   ],
   "source": [
    "num = (input(\"숫자 입력\"))\n",
    "\n",
    "# 사용자에게 숫자를 입력받은 후 +10 한 결과 출력\n",
    "if num.isdigit():\n",
    "    num =int(num)+10\n",
    "    print(num)\n",
    "else:\n",
    "    print(\"숫자를 입력하세요\")\n"
   ]
  }
